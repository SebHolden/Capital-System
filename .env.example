# Pooled URL for runtime (Neon pooler / Vercel). Use ?sslmode=require on Neon.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct URL for Prisma migrations (same host without -pooler). Required on Vercel builds.
DIRECT_DATABASE_URL="postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require"
EXECUTION_MODE=mock
ENABLE_LIVE_TRADING=false

# Base URL app (obbligatoria in produzione per Origin check CSRF)
# APP_BASE_URL=http://localhost:3000

# Auth app privata — opzionale in development, OBBLIGATORIA in production (NODE_ENV=production)
# APP_PASSWORD=

# EXECUTION_MODE in .env sincronizza UserSettings.executionMode al primo avvio (fonte runtime: DB)

# FX (Finnhub USD -> EUR)
FX_PROVIDER=exchangerate.host
# Fallback offline se API FX non disponibile (USD per 1 EUR, es. 1.09 => EUR_USD_RATE=0.917)
EUR_USD_RATE=

# Price providers (server-only)
# Opzionale — senza key, ETF/azioni usano prezzo medio (manual)
FINNHUB_API_KEY=
PRICE_STALE_MINUTES=15
PRICE_CACHE_SECONDS=60
# Cooldown default (override in UserSettings.rejectedOrderCooldownMinutes)
REJECTED_ORDER_COOLDOWN_MINUTES=15
# PENDING senza execution log: dopo questa soglia (ms) l'ordine viene marcato REJECTED
# PENDING_EXECUTION_STALE_MS=120000

# Broker keys (Milestone 6+, server-only)
EXECUTION_RATE_LIMIT_PER_MIN=10

# Backtest (Milestone 7+, server-only)
BACKTEST_DEFAULT_COMMISSION_BPS=10
BACKTEST_DEFAULT_SLIPPAGE_BPS=10
BACKTEST_MAX_YEARS=5

# Paper signals (Milestone 8+, server-only)
PAPER_MIN_BACKTEST_RETURN_PCT=0
PAPER_MAX_BACKTEST_DRAWDOWN_PCT=25
PAPER_PROMOTION_MIN_SIGNALS=3
PAPER_PROMOTION_MIN_AVG_30D_PCT=0
PAPER_MAX_MAE_PCT=15
PAPER_WIN_THRESHOLD_PCT=2
PAPER_LOSS_THRESHOLD_PCT=-2
PAPER_MIN_BARS_FOR_30D=25
PAPER_PROMOTION_MIN_WIN_RATE_PCT=40

# Data quality (Historical Data Quality milestone)
MIN_DATA_QUALITY_SCORE=60
MIN_BARS_FOR_EVALUATION=30

# Walk-forward validation (default: enabled)
WALKFORWARD_REQUIRED_FOR_PAPER=true
WALKFORWARD_MIN_SCORE=0.6
WALKFORWARD_TRAIN_BARS=180
WALKFORWARD_TEST_BARS=60
WALKFORWARD_STEP_BARS=30
WALKFORWARD_MIN_SCORE_FOR_PAPER=0.5
MAX_OVERFIT_SCORE_FOR_PAPER=0.6
MIN_DATA_QUALITY_FOR_PAPER=50

# Reports (Milestone 10+, optional benchmark symbol for monthly report)
# REPORTS_BENCHMARK_SYMBOL=BTC

# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# Broker stub (fase futura — non eseguono ordini reali)
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=
# IB_GATEWAY_HOST=127.0.0.1
# IB_GATEWAY_PORT=4002

# Live trading (requires ENABLE_LIVE_TRADING=true)
# LIVE_TRADING_PASSPHRASE=
# LIVE_DEFAULT_MAX_ORDER_AMOUNT=500
# LIVE_DEFAULT_MAX_DAILY_AMOUNT=2000
# LIVE_DEFAULT_MAX_MONTHLY_AMOUNT=10000
